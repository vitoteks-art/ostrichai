# Subscription System Environment Variables
# Copy this file to .env and fill in your actual values

# ========================================
# FLUTTERWAVE PAYMENT PROVIDER
# ========================================
# Get these from your Flutterwave dashboard: https://dashboard.flutterwave.com
VITE_FLUTTERWAVE_PUBLIC_KEY=flw_pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=flw_sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_HASH=your_webhook_secret_hash_here

# ========================================
# PAYSTACK PAYMENT PROVIDER
# ========================================
# Get these from your Paystack dashboard: https://dashboard.paystack.com
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# WEBHOOK ENDPOINTS
# ========================================
# URLs where payment providers will send webhook notifications
FLUTTERWAVE_WEBHOOK_URL=https://your-domain.com/api/webhooks/flutterwave
PAYSTACK_WEBHOOK_URL=https://your-domain.com/api/webhooks/paystack

# ========================================
# EMAIL CONFIGURATION (for invoices)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ========================================
# NIGERIAN BUSINESS DETAILS
# ========================================
BUSINESS_NAME="Your Company Name"
BUSINESS_EMAIL=info@yourcompany.com
BUSINESS_PHONE="+2348012345678"
BUSINESS_ADDRESS="123 Business Street, Lagos, Nigeria"
CAC_NUMBER="RC123456"  # Corporate Affairs Commission number
TIN="123456789"        # Tax Identification Number

# ========================================
# SUBSCRIPTION SETTINGS
# ========================================
DEFAULT_TRIAL_DAYS=7
VAT_RATE=7.5          # Nigerian VAT rate
CURRENCY=NGN          # Default currency

# ========================================
# SECURITY
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-32-character-encryption-key-here

# ========================================
# API SETTINGS
# ========================================
API_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_TIMEOUT_SECONDS=30

# ========================================
# FRONTEND SETTINGS
# ========================================
VITE_APP_NAME="Creative AI Platform"
VITE_APP_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
NODE_ENV=development
DEBUG=subscription:*,payment:*

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual credentials
# 3. Set up webhooks in Flutterwave and Paystack dashboards
# 4. Configure email settings for invoice delivery
# 5. Test payment flows in development environment
# 6. Update production environment variables before deployment